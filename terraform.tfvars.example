# Copy this file to terraform.tfvars and adjust the values for your deployment.
# terraform.tfvars is gitignored so your real values are never committed.

# Subscription to deploy into. Alternatively export ARM_SUBSCRIPTION_ID and omit this.
# subscription_id = "00000000-0000-0000-0000-000000000000"

project_name        = "cloudcare"
environment         = "dev"
location            = "eastus2"
resource_group_name = "cloudcare-infra"

tags = {
  owner       = "platform-team"
  cost_center = "1234"
}

# Networking
vnet_address_space = ["10.0.0.0/16"]

# AKS
kubernetes_version = "1.30"
aks_sku_tier       = "Free" # use "Standard" or "Premium" for an SLA-backed control plane

system_node_pool = {
  vm_size    = "Standard_DS2_v2"
  node_count = 1
  min_count  = 1
  max_count  = 10
}

# On-demand pool for general workloads (ingress, apps).
user_node_pool = {
  vm_size   = "Standard_DS2_v2"
  min_count = 1
  max_count = 5
}

# Cost optimization: Spot pool for interruptible workloads (scales to zero).
enable_spot_node_pool = true
spot_node_pool = {
  vm_size   = "Standard_DS2_v2"
  min_count = 0
  max_count = 3
  max_price = -1 # pay up to the on-demand price
}

# Serverless burst to Azure Container Instances (off by default).
# enable_virtual_nodes = true

# Front Door
# Private Link to the internal ingress origin requires the Premium SKU.
frontdoor_sku = "Standard_AzureFrontDoor"

# Restrict the public API server to your egress CIDRs (recommended).
# Leave empty for an unrestricted public API server (gated by Entra ID + RBAC).
# api_server_authorized_ip_ranges = ["203.0.113.10/32"]
